# -----------------------------------------------------------------------
# Turso (libSQL) database
# -----------------------------------------------------------------------
# When deployed on Vercel with the Turso integration, these variables are
# injected automatically with a "blueprint_" prefix (matching the Vercel
# project name). The app checks the prefixed name first, then falls back
# to the unprefixed name for local dev or other hosting environments.
#
# Vercel (auto-injected by Turso integration):
#   blueprint_TURSO_DATABASE_URL=libsql://...
#   blueprint_TURSO_AUTH_TOKEN=eyJ...
#
# Local dev / non-Vercel environments:
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# -----------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------
RESEND_API_KEY=re_your_api_key

# -----------------------------------------------------------------------
# AI (Anthropic Claude)
# -----------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key

# -----------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-32-char-secret-here

# -----------------------------------------------------------------------
# App
# -----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
